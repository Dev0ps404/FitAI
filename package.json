{
  "name": "fitai",
  "private": true,
  "version": "1.0.0",
  "description": "FitAI monorepo workspace (client + server)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c magenta,cyan \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server",
    "lint": "npm run lint --workspace client && npm run lint --workspace server",
    "format": "npm run format --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20"
  }
}
